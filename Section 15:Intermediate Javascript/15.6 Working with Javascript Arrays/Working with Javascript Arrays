// Initialize an empty array to store guest names
let guestNames = [];

// Function to add a guest's name
function addGuest(name) {
  guestNames.push(name);
}

// Function to get the total number of guests
function getGuestCount() {
  return guestNames.length;
}

// Function to list all guest names
function listGuests() {
  return guestNames.join(", ");
}

// Example usage
addGuest ("Angela");
addGuest ("Ciprian");
addGuest ("John")


console.log("Total Guests:", getGuestCount()); // Outputs the total number of guests
console.log("Guest List:", listGuests()): //Outputs the list of all the guests
